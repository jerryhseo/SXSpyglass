<?xml version="1.0"?>
<!DOCTYPE service-builder PUBLIC "-//Liferay//DTD Service Builder 7.2.0//EN" "http://www.liferay.com/dtd/liferay-service-builder_7_2_0.dtd">

<service-builder dependency-injector="ds" package-path="com.sx.spyglass">
	<namespace>SXSpyglass</namespace>
	<!--<entity data-source="sampleDataSource" local-service="true" name="Foo" remote-service="false" session-factory="sampleSessionFactory" table="foo" tx-manager="sampleTransactionManager uuid="true"">-->
	<entity local-service="true" name="ScienceApp" remote-service="true" uuid="true"  trash-enabled="true" uuid-accessor="true">

		<!-- PK fields -->

		<column name="scienceAppId" primary="true" type="long" />

		<!-- Group instance -->

		<column name="groupId" type="long" />

		<!-- Audit fields -->

		<column name="companyId" type="long" />
		<column name="userId" type="long" />
		<column name="userName" type="String" />
		<column name="createDate" type="Date" />
		<column name="modifiedDate" type="Date" />
		
		<!-- Status fields for workflow -->
		<column name="status" type="int" />
		<column name="statusByUserId" type="long" />
		<column name="statusByUserName" type="String" />
		<column name="statusDate" type="Date" />
		
		<!-- Field for Staging --> 
		<column name="lastPublishDate" type="Date" />

		<!-- Other fields -->

		<column name="appName" type="String" />
		<column name="appVersion" type="String" />
		<column name="appType" type="String" />
		<column name="exeFileName" type="String" />
		<column name="displayName" type="String" localized="true" />
		<column name="description" type="String" localized="true" />
		<column name="startScript" type="String"/>
		<column name="finishScript" type="String"/>

		<!-- Order -->

		<order by="asc">
			<order-column name="appName" />
		</order>

		<!-- Finder methods -->

		<finder name="GroupId" return-type="Collection">
			<finder-column name="groupId" />
		</finder>
		<finder name="UserId" return-type="Collection">
			<finder-column name="userId" />
		</finder>
		<finder name="Status" return-type="Collection">
			<finder-column name="status" />
		</finder>
		<finder name="G_U" return-type="Collection">
			<finder-column name="groupId" />
			<finder-column name="userId" />
		</finder>
		<finder name="G_S" return-type="Collection">
			<finder-column name="groupId" />
			<finder-column name="status" />
		</finder>
		<finder name="U_S" return-type="Collection">
			<finder-column name="userId" />
			<finder-column name="status" />
		</finder>
		<finder name="G_U_S" return-type="Collection">
			<finder-column name="groupId" />
			<finder-column name="userId" />
			<finder-column name="status" />
		</finder>
		
		<finder name="AppName" return-type="Collection">
			<finder-column name="appName" />
		</finder>
		<finder name="NameVersion" return-type="Collection">
			<finder-column name="appName" />
			<finder-column name="appVersion" />
		</finder>
		<finder name="AppType" return-type="Collection">
			<finder-column name="appType" />
		</finder>

		<!-- References -->

		<reference entity="AssetEntry" package-path="com.liferay.portlet.asset" />
		<reference entity="AssetLink" package-path="com.liferay.portlet.asset" />
		<reference entity="RatingsStats" package-path="com.liferay.portlet.ratings" />
		<reference entity="TrashEntry" package-path="com.liferay.portlet.trash" />
		<reference entity="TrashVersion" package-path="com.liferay.portlet.trash" />
		<reference entity="WorkflowInstanceLink" package-path="com.liferay.portal" />
	</entity>
	
	<entity name="AppPort" local-service="true" uuid="false" remote-service="false">
		<column name="appPortId" primary="true" type="long"></column>
		
		<column name="scienceAppId" type="long"></column>
		<column name="dataTypeId" type="long"></column>
		<column name="optionName" type="String"></column>
		<column name="portType" type="String"></column>
		
		<finder name="AppId" return-type="Collection">
			<finder-column name="dataTypeId" ></finder-column>
		</finder>
		<finder name="portType" return-type="Collection">
			<finder-column name="portType" ></finder-column>
		</finder>
		<finder name="AppPortType" return-type="Collection">
			<finder-column name="dataTypeId" ></finder-column>
			<finder-column name="portType" ></finder-column>
		</finder>
	</entity>
</service-builder>